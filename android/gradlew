##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#       noncompliant, but you have some other compliant shell such as ksh or
#       bash, then run this script with that shell:
#
#           ksh Gradle
#
#       Or, after fixing the shebang line:
#
#           #!/usr/bin/env ksh
#           ./gradlew
#
#   (2) This script attempts to guess the path to the Java installation
#       required to run Gradle. If you have installed Java in a non-standard
#       location, see the appropriate section below.
#
##############################################################################

##############################################################################
#
# Gradle start up script for POSIX generated by Gradle.
#
# Important for running:
#
# (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#     noncompliant, but you have some other compliant shell such as ksh or
#     bash, then run this script with that shell:
#
#         ksh Gradle
#
#     Or, after fixing the shebang line:
#
#         #!/usr/bin/env ksh
#         ./gradlew
#
# (2) This script attempts to guess the path to the Java installation
#     required to run Gradle. If you have installed Java in a non-standard
#     location, see the appropriate section below.
#
##############################################################################

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD=maximum

warn () {
    echo "$*"
} >&2

die () {
    echo
    echo "$*"
    echo
    exit 1
} >&2

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
darwin=false
nonstop=false
case "$( uname )" in                #(
  CYGWIN* )         cygwin=true  ;; #(
  Darwin* )         darwin=true  ;; #(
  MSYS* | MINGW* )  msys=true    ;; #(
  NONSTOP* )        nonstop=true ;;
esac

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD="$JAVA_HOME/jre/sh/java"
    else
        JAVACMD="$JAVA_HOME/bin/java"
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
else
    JAVACMD="java"
    which java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH.

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
fi

# Increase the maximum file descriptors if we can.
if ! "$cygwin" && ! "$darwin" && ! "$nonstop" ; then
    case $MAX_FD in #(
      max*)
        # In POSIX sh, ulimit -H is undefined. That's why the result is checked to see if it worked.
        # shellcheck disable=SC3045
        MAX_FD=$( ulimit -H -n ) ||
            warn "Could not query maximum file descriptor limit"
    esac
    case $MAX_FD in  #(
      '' | soft) :;; #(
      *)
        # In POSIX sh, ulimit -n is undefined. That's why the result is checked to see if it worked.
        # shellcheck disable=SC3045
        ulimit -n "$MAX_FD" ||
            warn "Could not set maximum file descriptor limit to $MAX_FD"
    esac
fi

# Collect all arguments for the java command, stacking in reverse order:
#   * args from the command line
#   * the main class name
#   * the classpath 'classpath'
#   * the -Dfile.encoding=UTF-8 for JVM behavior (for Gradle)
#   * the -Djava.security.egd=file:/dev/urandom for JVM behavior (for Gradle)
#   * potentially the Gradle daemon JVM options

# For Cygwin or MSYS, switch paths to Windows format before running java
if "$cygwin" || "$msys" ; then
    APP_HOME=$( cygpath --path --mixed "$APP_HOME" )
    CLASSPATH=$( cygpath --path --mixed "$CLASSPATH" )

    JAVACMD=$( cygpath --unix "$JAVACMD" )

    # Now convert the arguments - list L limited to 9
    for arg do
        if [ -n "$arg" ] ; then
            args="$args \"$( cygpath --path --mixed "$arg" )\""
        fi
    done
else
    args=""
    for arg do
        if [ -n "$arg" ] ; then
            args="$args \"$arg\""
        fi
    done
fi

# Collect JVM options and remove duplicates
ORIGINAL_JVM_OPTS=""
while IFS= read -r line; do
    ORIGINAL_JVM_OPTS="$ORIGINAL_JVM_OPTS $line"
done <<< "$( echo "$JAVA_OPTS $GRADLE_OPTS $DEFAULT_JVM_OPTS" | sed -e 's/  */ /g' -e 's/^ *//' -e 's/ *$//' )"

# We need to process all args in order to avoid any bad collisions in the set command.
while [ -n "$1" ]; do
    if [ "$1" = "--" ]; then
        shift
        for arg
        do
            set -- "$@" "$arg"
        done
        break
    fi
    set -- "$@" "$1"
    shift
done

set -- $ORIGINAL_JVM_OPTS "$@"

eval "set -- $(
    printf '%s\n' "$DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS" |
    sed -e 's/  */ /g' -e 's/^ *//' -e 's/ *$//' -e 's/^-Xrs$//' -e 's/^-Xrs  *//' |
    tr '\n' ' '
)" '"$@"'

exec "$JAVACMD" "$@
